rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Games: any signed-in player can read (enables spectating) and any
    // signed-in player can write via the client engine's transactions.
    // Move legality is enforced by the shared rules engine on every client;
    // this is a family game built on trust, not an anti-cheat system.
    match /games/{gameId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;
      allow update: if signedIn();
      allow delete: if false;

      // Append-only action log for replays.
      match /actions/{actionId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update, delete: if false;
      }

      // Spectator presence heartbeats: each watcher owns exactly one doc
      // keyed by their uid.
      match /watchers/{watcherUid} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == watcherUid;
      }

      // Blunder reports for AI training: anyone who can see the game can
      // file one; append-only except the reporter retracting their own.
      match /blunders/{blunderId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.reporter.uid == request.auth.uid;
        allow update: if false;
        allow delete: if signedIn() && resource.data.reporter.uid == request.auth.uid;
      }
    }

    // Table invites: created by the sender, retired (accepted/declined) by
    // either side. Doc ids are {gameId}_{toUid}, so re-invites overwrite
    // rather than pile up.
    match /invites/{inviteId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }

    // Profiles: readable by any signed-in user, writable only by the owner.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;

      match /history/{gameId} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == uid;
      }
    }
  }
}
